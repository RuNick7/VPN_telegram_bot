# Telegram Bot Configuration (admin_bot)
Admin_bot_token=
ADMIN_IDS=
# Токен user_bot для рассылки
USER_BOT_TOKEN=

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Remnawave API
REMNAWAVE_BASE_URL=
REMNAWAVE_USERNAME=
REMNAWAVE_PASSWORD=
REMNAWAVE_TOKEN=
# Optional alias for API token (used by admin_bot too)
REMNAWAVE_API_KEY=
REMNAWAVE_TIMEOUT_SECONDS=5

# Database Configuration
USER_BOT_DB_PATH=../user_bot/data/subscription.db
DB_PATH=./user_bot/data/subscription.db

# Backup Configuration (admin_bot)
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
SUBSCRIPTION_DB_BACKUP_DIR=./backups/subscription_db
REMNAWAVE_BACKUP_ENABLED=true

# Logging Configuration (admin_bot)
LOG_LEVEL=INFO
LOG_FILE=./logs/bot.log

# Monitoring Configuration (admin_bot)
MONITOR_INTERVAL_MINUTES=5
NODE_RAM_MAX_PERCENT=90

# Subscription defaults (user_bot)
TRIAL_DAYS=30
TIMEZONE=Moscow
STATUS_CHANNEL_URL=https://t.me/vpn_channel
FAQ_URL=https://gitbook.io/
SHOW_VIDEO_INSTRUCTIONS=false

# Internal squads
INTERNAL_SQUAD_MAX_USERS=175
INTERNAL_SQUAD_PREFIX=internal

# LTE traffic-limit monitor (admin_bot)
LTE_TRAFFIC_MONITOR_ENABLED=true
LTE_SQUAD_NAME=LTE
LTE_FREE_GB_PER_30D=1
LTE_PERIOD_DAYS=30
# If empty, monitor will detect LTE nodes by name keywords.
LTE_LIMITED_NODE_UUIDS=
LTE_LIMITED_NODE_NAME_KEYWORDS=LTE

# Free mode: when subscription_ends is in the past, user is moved into a single
# squad with limited free servers. Create this squad in Remnawave panel manually
# and put the desired free inbound(s) into it.
FREE_SQUAD_NAME=FREE
# Subscription expiration monitor (admin_bot). Periodically demotes/promotes
# users between paid internal-* squads and the FREE squad based on the
# subscription_ends field stored locally (we keep panel expireAt at infinity).
SUBSCRIPTION_EXPIRE_MONITOR_ENABLED=true
# ISO timestamp written to Remnawave's expireAt for every user. Effectively
# disables panel-side expiration; we count days locally instead.
INFINITE_EXPIRE_DATE=2099-12-31T23:59:59.000Z

# === Web cabinet (web/backend + web/frontend) ===
# JWT и cookie сессии (на проде SECURE=true)
JWT_SECRET=replace_with_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=120
SESSION_COOKIE_NAME=kairavpn_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax

# Лимит запросов на /api/auth/*
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# TTL одноразовых токенов (мин)
MAGIC_LINK_TTL_MINUTES=15
TG_LINK_TTL_MINUTES=15

# Публичные URL — должны совпадать с тем, что отдаёт nginx
APP_BASE_URL=https://app.kairavpn.pro
API_BASE_URL=https://app.kairavpn.pro
WEB_PAYMENT_RETURN_URL=https://app.kairavpn.pro/cabinet/payment-callback
CORS_ORIGINS=https://app.kairavpn.pro

# Email-отправитель (mock | smtp). На проде smtp обязательный — иначе magic-link не отправится.
EMAIL_SENDER_MODE=smtp
EMAIL_APP_NAME=KairaVPN
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=KairaVPN
SMTP_USE_TLS=false
SMTP_USE_SSL=true
SMTP_TIMEOUT_SECONDS=15

# Имя бота — без @
TELEGRAM_BOT_USERNAME=KairaVPN_Bot

# Внутренний секрет для loopback-вызовов user_bot ↔ web-api
WEB_INTERNAL_SECRET=replace_with_another_random_string

# Web Push (VAPID). Сгенерируй один раз: npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:no-reply@example.com
