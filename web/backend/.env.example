WEB_ENV=development
WEB_HOST=127.0.0.1
WEB_PORT=8000

# JWT / session
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=120
SESSION_COOKIE_NAME=kairavpn_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Rate limit
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Magic-link / Telegram link TTL (minutes)
MAGIC_LINK_TTL_MINUTES=15
TG_LINK_TTL_MINUTES=15

# Frontend / API base URLs
APP_BASE_URL=http://127.0.0.1:3000
API_BASE_URL=http://127.0.0.1:8000
WEB_PAYMENT_RETURN_URL=http://127.0.0.1:3000/cabinet
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Email sender (mock | smtp)
EMAIL_SENDER_MODE=mock
EMAIL_APP_NAME=KairaVPN
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=no-reply@example.com
# SMTP_FROM_NAME=KairaVPN
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_TIMEOUT_SECONDS=15

# Telegram bot (used for deep-link username and widget signature validation)
TELEGRAM_BOT_USERNAME=KairaVPN_Bot
USER_BOT_TOKEN=
# (optional override) TELEGRAM_BOT_TOKEN=

# Public links shared between bot and site
SUPPORT_URL=https://t.me/nitratex1
FAQ_URL=https://nitratex-company.gitbook.io/kairavpn/
STATUS_CHANNEL_URL=https://t.me/KairaVPN_channel

# Payment integrations
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
YOOKASSA_WEBHOOK_ALLOWED_CIDRS=

# Remnawave
REMNAWAVE_BASE_URL=
REMNAWAVE_USERNAME=
REMNAWAVE_PASSWORD=
# REMNAWAVE_TOKEN=

# Internal-only secret used by user_bot to confirm Telegram link tokens
# and to dispatch web-push notifications after payment events.
WEB_INTERNAL_SECRET=change_me_internal

# Web Push (VAPID). Сгенерируй один раз: npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:no-reply@example.com
