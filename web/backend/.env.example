WEB_ENV=development
WEB_HOST=127.0.0.1
WEB_PORT=8000
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=120
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
SESSION_COOKIE_NAME=kairavpn_session
SESSION_COOKIE_SECURE=false
MAGIC_LINK_TTL_MINUTES=15
APP_BASE_URL=http://127.0.0.1:5173
EMAIL_SENDER_MODE=mock
WEB_PAYMENT_RETURN_URL=http://127.0.0.1:5173/cabinet
# Optional extra secret header for webhook hardening.
# If set, backend expects x-kaira-webhook-secret with the same value.
YOOKASSA_WEBHOOK_SECRET=
# Optional source IP allowlist for webhook endpoint.
# Example: 185.71.76.0/27,185.71.77.0/27,77.75.153.0/25,77.75.156.11/32,77.75.156.35/32
YOOKASSA_WEBHOOK_ALLOWED_CIDRS=

# Required core secrets and integrations (validated on backend startup)
JWT_SECRET=change_me
TELEGRAM_BOT_TOKEN=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
REMNAWAVE_BASE_URL=
REMNAWAVE_USERNAME=
REMNAWAVE_PASSWORD=
