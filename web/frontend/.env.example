# Публичный URL фронта (используется в meta, manifest, OG-тегах)
NEXT_PUBLIC_SITE_URL=https://app.kairavpn.pro

# Публичная ссылка на FAQ (показывается на лендинге и в кабинете)
NEXT_PUBLIC_FAQ_URL=https://nitratex-company.gitbook.io/kairavpn/

# Внутренний адрес FastAPI. Next.js (SSR + rewrites) ходит на него по 127.0.0.1.
# В проде systemd-юнит kaira-web-api слушает 127.0.0.1:8001.
API_BASE_URL=http://127.0.0.1:8001
